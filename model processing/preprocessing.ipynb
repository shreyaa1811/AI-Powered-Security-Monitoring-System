   "source": [
    "normal_df = pd.read_csv(r"C:\path\to\your\project\data\normal_logs.csv")",
    "attack_df = pd.read_csv(r"C:\path\to\your\project\data\attack_logs.csv")"
   ]
  },
  {
   "cell_type": "code",
   "execution_count": 4,
   "id": "1159fa0a",
   "metadata": {},
   "outputs": [],
   "source": [
    "normal_sampled = normal_df.sample(n=len(attack_df),random_state=42)\n",
    "balanced_df = pd.concat([normal_sampled,attack_df],ignore_index=True)\n",
    "balanced_df = balanced_df.sample(frac=1, random_state=42).reset_index(drop=True)"
   ]
  },

   "source": [
    "#Preprocessing timestamps\n",
    "balanced_df['timestamp'] = pd.to_datetime(balanced_df['timestamp'],errors='coerce')\n",
    "balanced_df['hour'] = balanced_df['timestamp'].dt.hour\n",
    "balanced_df['day'] = balanced_df['timestamp'].dt.day\n",
    "balanced_df['month'] = balanced_df['timestamp'].dt.month\n",
    "balanced_df['weekday'] = balanced_df['timestamp'].dt.weekday\n",
    "balanced_df.drop(columns=['timestamp'],inplace=True)"
   ]
  },
  {
   "cell_type": "code",
   "execution_count": 9,
   "id": "74021847",
   "metadata": {},
   "outputs": [],
   "source": [
    "#One hot encoding for event types\n",
    "balanced_df = pd.get_dummies(balanced_df,columns=['event_type'])"
   ]
  },
  {
   "cell_type": "code",
   "execution_count": 10,
   "id": "bbfde1f5",
   "metadata": {},
   "outputs": [],
   "source": [
    "#Label Encoding for labels\n",
    "balanced_df['label_num'] = balanced_df['label'].map({'attack':1,'normal':0})"
   ]
  },
  {
   "cell_type": "code",
   "execution_count": 11,
   "id": "1a9c3633",
   "metadata": {},
   "outputs": [],
   "source": [
    "#Converting ip addresses to numerical values for model understanding\n",
    "import ipaddress\n",
    "import numpy as np \n",
    "\n",
    "def safe_ip(ip) :\n",
    "    try :\n",
    "        return int(ipaddress.IPv4Address(ip))\n",
    "    except :\n",
    "        return np.nan \n",
    "\n",
    "balanced_df['source_ip_int'] = balanced_df['source_ip'].apply(safe_ip)\n",
    "balanced_df = balanced_df.dropna(subset=['source_ip_int'])"
   ]
  },
  {
   "cell_type": "code",
   "execution_count": 12,
   "id": "337e64a9",
   "metadata": {},
   "outputs": [],
   "source": [
    "#Features and target\n",
    "X = balanced_df.drop(columns=['label','label_num','source_ip'])\n",
    "y = balanced_df['label_num']"
   ]
